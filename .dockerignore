# Keep the build context small and never leak local secrets into the image.

# Dependencies (reinstalled from the lockfile inside the image)
node_modules
.pnp
.pnp.*
.yarn

# Build output (regenerated by `next build` in the image)
.next
out
build
coverage
*.tsbuildinfo
next-env.d.ts

# Secrets and local env — the real values are injected by EasyPanel.
# Only the example template is kept so nothing sensitive ships in the image.
.env
.env.*
!.env.local.example
!.env.example

# Version control / CI / editor cruft
.git
.gitignore
.github
.vscode
.idea
.DS_Store
*.pem

# Docker + docs (not needed at runtime)
Dockerfile
.dockerignore
docker-compose*.yml
*.md
docs

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
